---
interface Props {
  title: string;
  category: string;
  beforeColor: string;
  afterColor: string;
  description: string;
}

const { title, category, beforeColor, afterColor, description } = Astro.props;
---

<div
  class="gallery-item rounded-sm overflow-hidden border border-gold/10 hover:border-gold/30 transition-all hover:shadow-xl group"
  data-category={category}
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <!-- Before/After side-by-side -->
    <div class="absolute inset-0 flex">
      <div
        class="w-1/2 flex items-center justify-center text-cream font-serif text-lg"
        style={`background-color: ${beforeColor}`}
      >
        <div class="text-center">
          <span class="block text-xs uppercase tracking-wider opacity-70 mb-1">Before</span>
          <span class="text-sm opacity-90">Photo Placeholder</span>
        </div>
      </div>
      <div
        class="w-1/2 flex items-center justify-center text-cream font-serif text-lg"
        style={`background-color: ${afterColor}`}
      >
        <div class="text-center">
          <span class="block text-xs uppercase tracking-wider opacity-70 mb-1">After</span>
          <span class="text-sm opacity-90">Photo Placeholder</span>
        </div>
      </div>
    </div>
    <!-- Divider line -->
    <div class="absolute top-0 bottom-0 left-1/2 w-0.5 bg-gold z-10"></div>
    <!-- Category badge -->
    <span
      class="absolute top-3 right-3 bg-wood/90 text-cream text-xs px-3 py-1 rounded-sm font-medium z-10 capitalize"
    >
      {category}
    </span>
  </div>
  <div class="p-5">
    <h3 class="font-serif text-lg text-wood group-hover:text-gold transition-colors">{title}</h3>
    <p class="text-sm text-charcoal-light mt-1">{description}</p>
  </div>
</div>
