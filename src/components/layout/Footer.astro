                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>
                10 Regency Dr Bldg B<br />
                Wylie, TX 75098
              </span>
            </li>
          </ul>

