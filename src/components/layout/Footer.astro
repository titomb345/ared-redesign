---
const currentYear = 2026;
---

<footer class="bg-wood text-cream/90 texture-wood">
  <div class="relative z-10">
    <!-- Main Footer -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <!-- Brand Column -->
        <div class="lg:col-span-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-gold rounded-sm flex items-center justify-center">
              <span class="text-wood font-serif font-bold text-lg">A</span>
            </div>
            <div>
              <span class="font-serif font-bold text-cream text-lg block leading-tight">ARED</span>
              <span class="text-xs text-cream/60 block">Furniture Repair & Restoration</span>
            </div>
          </div>
          <p class="text-cream/70 text-sm leading-relaxed mt-4">
            Family-owned and operated since 1980. Serving the Dallas-Fort Worth metroplex with
            expert furniture repair, antique restoration, and custom upholstery.
          </p>
        </div>

        <!-- Quick Links -->
        <div>
          <h3 class="font-serif text-gold text-lg mb-4">Quick Links</h3>
          <ul class="space-y-2">
            <li>
              <a href="/" class="text-cream/70 hover:text-gold transition-colors text-sm">Home</a>
            </li>
            <li>
              <a href="/services/" class="text-cream/70 hover:text-gold transition-colors text-sm"
                >Services</a
              >
            </li>
            <li>
              <a href="/portfolio/" class="text-cream/70 hover:text-gold transition-colors text-sm"
                >Portfolio</a
              >
            </li>
            <li>
              <a href="/about/" class="text-cream/70 hover:text-gold transition-colors text-sm"
                >About</a
              >
            </li>
            <li>
              <a href="/contact/" class="text-cream/70 hover:text-gold transition-colors text-sm"
                >Contact</a
              >
            </li>
            <li>
              <a href="/blog/" class="text-cream/70 hover:text-gold transition-colors text-sm"
                >Blog</a
              >
            </li>
            <li>
              <a
                href="/privacy-policy/"
                class="text-cream/70 hover:text-gold transition-colors text-sm">Privacy Policy</a
              >
            </li>
            <li>
              <a
                href="/terms-of-use/"
                class="text-cream/70 hover:text-gold transition-colors text-sm">Terms of Use</a
              >
            </li>
          </ul>
        </div>

        <!-- Business Hours -->
        <div>
          <h3 class="font-serif text-gold text-lg mb-4">Business Hours</h3>
          <ul class="space-y-2 text-sm">
            <li class="flex justify-between text-cream/70">
              <span>Monday - Friday</span>
              <span class="text-cream/90">9am - 5pm</span>
            </li>
            <li class="flex justify-between text-cream/70">
              <span>Saturday</span>
              <span class="text-cream/90">9am - 3:30pm</span>
            </li>
            <li class="flex justify-between text-cream/70">
              <span>Sunday</span>
              <span class="text-cream/90">Closed</span>
            </li>
          </ul>
          <div class="mt-6 p-3 bg-gold/10 rounded-sm border border-gold/20">
            <p class="text-gold text-sm font-semibold">Free Pickup & Delivery</p>
            <p class="text-cream/60 text-xs mt-1">Throughout the DFW metroplex</p>
          </div>
        </div>

        <!-- Contact Info -->
        <div>
          <h3 class="font-serif text-gold text-lg mb-4">Contact</h3>
          <ul class="space-y-3 text-sm">
            <li>
              <a
                href="tel:+12146826371"
                class="flex items-start gap-2 text-cream/70 hover:text-gold transition-colors"
              >
                <svg
                  class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                <span>(214) 682-6371</span>
              </a>
            </li>
            <li class="flex items-start gap-2 text-cream/70">
              <svg
                class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>
                10 Regency Dr Bldg B<br />
                Wylie, TX 75098
              </span>
            </li>
          </ul>

          <!-- Social Links Placeholder -->
          <div class="flex gap-3 mt-6">
            <a
              href="#"
              aria-label="Facebook"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24"
                ><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              aria-label="Google Business"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"
                ></path><path
                  d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                ></path><path
                  d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                ></path><path
                  d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                ></path></svg
              >
            </a>
            <a
              href="#"
              aria-label="Yelp"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                ></path></svg
              >
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-cream/10">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-3"
      >
        <p class="text-cream/50 text-sm">
          &copy; {currentYear} ARED Furniture Repair & Antique Restoration. All rights reserved.
        </p>
        <p class="text-cream/40 text-xs">
          Website by <a
            href="https://billbergquist.dev"
            class="text-gold/70 hover:text-gold transition-colors"
            target="_blank"
            rel="noopener noreferrer">BillBergquist.dev</a
          >
        </p>
      </div>
    </div>
  </div>
</footer>
