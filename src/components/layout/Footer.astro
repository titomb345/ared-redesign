---
import { Image } from 'astro:assets';
import logo from '../../assets/images/logo.png';

const currentYear = 2026;
---

<footer class="bg-wood text-cream/90 texture-wood">
  <div class="relative z-10">
    <!-- Main Footer -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
        <!-- Brand Column -->
        <div class="sm:col-span-2 lg:col-span-1 text-center sm:text-left">
          <div class="mb-4 flex justify-center sm:justify-start">
            <Image
              src={logo}
              alt="ARED Furniture Repair & Antique Restoration"
              width={140}
              height={80}
              class="h-14 w-auto brightness-0 invert opacity-90"
            />
          </div>
          <p class="text-cream/70 text-sm leading-relaxed mt-4">
            Family-owned and operated since 1980. Serving the Dallas-Fort Worth metroplex with
            expert furniture repair, antique restoration, and custom upholstery.
          </p>
        </div>

        <!-- Quick Links -->
        <div class="text-center sm:text-left">
          <h3 class="font-serif text-gold text-lg mb-4">Quick Links</h3>
          <ul class="grid grid-cols-2 gap-x-6 gap-y-2">
            <li>
              <a href="/" class="text-cream/70 hover:text-gold transition-colors text-sm">Home</a>
            </li>
            <li>
              <a href="/services/" class="text-cream/70 hover:text-gold transition-colors text-sm">Services</a>
            </li>
            <li>
              <a href="/portfolio/" class="text-cream/70 hover:text-gold transition-colors text-sm">Portfolio</a>
            </li>
            <li>
              <a href="/about/" class="text-cream/70 hover:text-gold transition-colors text-sm">About</a>
            </li>
            <li>
              <a href="/contact/" class="text-cream/70 hover:text-gold transition-colors text-sm">Contact</a>
            </li>
            <li>
              <a href="/privacy-policy/" class="text-cream/70 hover:text-gold transition-colors text-sm">Privacy Policy</a>
            </li>
            <li>
              <a href="/terms-of-use/" class="text-cream/70 hover:text-gold transition-colors text-sm">Terms of Use</a>
            </li>
          </ul>
        </div>

        <!-- Business Hours -->
        <div class="text-center sm:text-left">
          <h3 class="font-serif text-gold text-lg mb-4">Business Hours</h3>
          <ul class="space-y-2 text-sm">
            <li class="flex justify-between text-cream/70">
              <span>Monday - Friday</span>
              <span class="text-cream/90">9am - 5pm</span>
            </li>
            <li class="flex justify-between text-cream/70">
              <span>Saturday</span>
              <span class="text-cream/90">9am - 3:30pm</span>
            </li>
            <li class="flex justify-between text-cream/70">
              <span>Sunday</span>
              <span class="text-cream/90">Closed</span>
            </li>
          </ul>
          <div class="mt-6 p-3 bg-gold/10 rounded-sm border border-gold/20">
            <p class="text-gold text-sm font-semibold">Free Pickup & Delivery</p>
            <p class="text-cream/60 text-xs mt-1">Throughout the DFW metroplex</p>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="text-center sm:text-left">
          <h3 class="font-serif text-gold text-lg mb-4">Contact</h3>
          <ul class="space-y-3 text-sm">
            <li>
              <a
                href="tel:+12146826371"
                class="flex items-start justify-center sm:justify-start gap-2 text-cream/70 hover:text-gold transition-colors"
              >
                <svg
                  class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
                <span>(214) 682-6371</span>
              </a>
            </li>
            <li class="flex items-start justify-center sm:justify-start gap-2 text-cream/70">
              <svg
                class="w-5 h-5 text-gold flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span>
                10 Regency Dr Bldg B<br />
                Wylie, TX 75098
              </span>
            </li>
          </ul>

          <!-- Social Links -->
          <div class="flex justify-center sm:justify-start gap-3 mt-6">
            <a
              href="https://www.facebook.com/FurnitureRepairing/"
              aria-label="Follow ARED on Facebook"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
            <a
              href="https://www.instagram.com/aredfurnituretx/"
              aria-label="Follow ARED on Instagram"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>
            <a
              href="https://x.com/aredfurnituretx"
              aria-label="Follow ARED on X (Twitter)"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href="https://www.pinterest.com/aredfurnituretx/"
              aria-label="Follow ARED on Pinterest"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/>
              </svg>
            </a>
            <a
              href="https://www.yelp.com/biz/ared-furniture-repair-and-antique-restoration-wylie"
              aria-label="Read ARED reviews on Yelp"
              target="_blank"
              rel="noopener noreferrer nofollow"
              class="w-9 h-9 bg-cream/10 rounded-sm flex items-center justify-center hover:bg-gold/20 transition-colors"
            >
              <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.16 12.594l-4.995 1.433c-.96.276-1.74-.8-1.176-1.63l2.905-4.308a1.072 1.072 0 011.596-.206 7.126 7.126 0 011.96 3.202c.186.618-.06 1.27-.59 1.51h.3zm-3.907 5.03l-2.9-4.312c-.563-.83.215-1.905 1.176-1.63l4.994 1.434c.53.24.776.892.59 1.51a7.126 7.126 0 01-1.96 3.201 1.072 1.072 0 01-1.596-.206l-.304.003zM12 15.9c0 1.1-.997 1.848-1.897 1.423L5.87 15.1a1.072 1.072 0 01-.546-1.384A7.037 7.037 0 018.43 10.53c.577-.33 1.287.065 1.35.75L12 15.9zm-1.887-7.46L5.884 10.66c-.9.425-1.897-.322-1.897-1.423l.178-4.62c.063-.685.773-1.08 1.35-.75a7.037 7.037 0 013.107 3.186 1.072 1.072 0 01-.546 1.384l.037.003zM12 2a2 2 0 00-2 2v5.478c0 1.127 1.047 1.906 1.978 1.47L12 10.94l.022.008c.931.436 1.978-.343 1.978-1.47V4a2 2 0 00-2-2z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-cream/10">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 pb-16 lg:pb-6 flex flex-col md:flex-row justify-between items-center text-center md:text-left gap-3"
      >
        <p class="text-cream/50 text-sm">
          &copy; {currentYear} ARED Furniture Repair & Antique Restoration. All rights reserved.
        </p>
        <p class="text-cream/40 text-xs">
          Website by <a
            href="https://billbergquist.dev"
            class="text-gold/70 hover:text-gold transition-colors"
            target="_blank"
            rel="noopener noreferrer nofollow">BillBergquist.dev</a
          >
        </p>
      </div>
    </div>
  </div>
</footer>
