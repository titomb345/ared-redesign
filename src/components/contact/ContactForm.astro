---

---

<form
  name="contact"
  method="POST"
  data-netlify="true"
  netlify-honeypot="bot-field"
  class="space-y-6"
  id="contact-form"
>
  <!-- Honeypot field for spam prevention -->
  <p class="hidden">
    <label>
      Don't fill this out if you're human: <input name="bot-field" />
    </label>
  </p>
  <input type="hidden" name="form-name" value="contact" />

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <!-- Name -->
    <div>
      <label for="name" class="block text-sm font-medium text-charcoal mb-2">
        Full Name <span class="text-burgundy">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full px-4 py-3 bg-cream border border-gold/20 rounded-sm text-charcoal placeholder-warm-gray focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
        placeholder="Your name"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-medium text-charcoal mb-2">
        Email Address <span class="text-burgundy">*</span>
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="w-full px-4 py-3 bg-cream border border-gold/20 rounded-sm text-charcoal placeholder-warm-gray focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
        placeholder="you@example.com"
      />
    </div>
  </div>

  <!-- Phone -->
  <div>
    <label for="phone" class="block text-sm font-medium text-charcoal mb-2">
      Phone Number <span class="text-burgundy">*</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      required
      autocomplete="tel"
      class="w-full px-4 py-3 bg-cream border border-gold/20 rounded-sm text-charcoal placeholder-warm-gray focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
      placeholder="(555) 123-4567"
    />
  </div>

  <!-- Service Interest -->
  <div>
    <label for="service" class="block text-sm font-medium text-charcoal mb-2">
      Service Needed
    </label>
    <select
      id="service"
      name="service"
      class="w-full px-4 py-3 bg-cream border border-gold/20 rounded-sm text-charcoal focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors"
    >
      <option value="">Select a service (optional)</option>
      <option value="Antique Restoration">Antique Furniture Restoration</option>
      <option value="Upholstery">Custom Upholstery & Repair</option>
      <option value="Refinishing">Refinishing & Refurbishing</option>
      <option value="Specialty Work">Specialty Work</option>
      <option value="Other">Other / Not Sure</option>
    </select>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block text-sm font-medium text-charcoal mb-2">
      Tell Us About Your Piece <span class="text-burgundy">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full px-4 py-3 bg-cream border border-gold/20 rounded-sm text-charcoal placeholder-warm-gray focus:border-gold focus:ring-1 focus:ring-gold/30 transition-colors resize-y"
      placeholder="Describe your furniture piece, the type of repair needed, and any other details that would help us give you an accurate estimate."
    ></textarea>
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="submit-btn"
    class="w-full sm:w-auto inline-flex items-center justify-center bg-burgundy text-cream px-8 py-4 rounded-sm font-semibold text-lg hover:bg-burgundy-dark transition-colors shadow-md hover:shadow-lg cursor-pointer"
  >
    <span id="submit-text">Send Message</span>
    <svg id="submit-icon" class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
    </svg>
    <svg id="submit-spinner" class="w-5 h-5 ml-2 animate-spin hidden" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
    </svg>
  </button>
</form>

<!-- Success Message -->
<div id="form-success" class="hidden">
  <div class="bg-forest/10 border border-forest/20 rounded-sm p-8 text-center">
    <svg class="w-12 h-12 text-forest mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <h3 class="font-serif text-2xl text-wood mb-2">Message Sent!</h3>
    <p class="text-charcoal-light">
      Thank you for reaching out. We will get back to you as soon as possible.
    </p>
    <p class="text-charcoal-light mt-2">
      Need a faster response? Call us at
      <a href="tel:+12146826371" class="text-gold font-semibold hover:text-gold-dark transition-colors">(214) 682-6371</a>.
    </p>
  </div>
</div>

<!-- Error Message -->
<div id="form-error" class="hidden">
  <div class="bg-burgundy/10 border border-burgundy/20 rounded-sm p-8 text-center">
    <svg class="w-12 h-12 text-burgundy mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <h3 class="font-serif text-2xl text-wood mb-2">Something Went Wrong</h3>
    <p class="text-charcoal-light">
      We could not send your message. Please try again, or call us directly at
      <a href="tel:+12146826371" class="text-gold font-semibold hover:text-gold-dark transition-colors">(214) 682-6371</a>.
    </p>
    <button
      id="retry-btn"
      class="mt-4 inline-flex items-center justify-center bg-burgundy text-cream px-6 py-3 rounded-sm font-semibold hover:bg-burgundy-dark transition-colors cursor-pointer"
    >
      Try Again
    </button>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const submitIcon = document.getElementById('submit-icon')!;
  const submitSpinner = document.getElementById('submit-spinner')!;
  const retryBtn = document.getElementById('retry-btn')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    submitText.textContent = 'Sending...';
    submitIcon.classList.add('hidden');
    submitSpinner.classList.remove('hidden');

    try {
      const formData = new FormData(form);
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString(),
      });

      if (response.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        throw new Error('Form submission failed');
      }
    } catch {
      form.classList.add('hidden');
      errorMsg.classList.remove('hidden');
    } finally {
      // Reset button state
      submitBtn.disabled = false;
      submitText.textContent = 'Send Message';
      submitIcon.classList.remove('hidden');
      submitSpinner.classList.add('hidden');
    }
  });

  retryBtn.addEventListener('click', () => {
    errorMsg.classList.add('hidden');
    form.classList.remove('hidden');
  });
</script>
