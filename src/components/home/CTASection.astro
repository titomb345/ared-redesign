---
import Button from '../ui/Button.astro';
---

<section class="py-20 md:py-28 reveal">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-wood font-bold">
      Ready to Restore Your Furniture?
    </h2>
    <div class="ornament mt-6">
      <div class="ornament-diamond"></div>
    </div>
    <p class="mt-6 text-lg text-charcoal-light max-w-2xl mx-auto leading-relaxed">
      Whether it is a cherished family heirloom or a flea market find with potential, we will bring
      it back to life. Contact us for a free estimate with pickup and delivery included.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/contact/" variant="primary" size="lg"> Get Your Free Estimate </Button>
      <Button href="tel:+12146826371" variant="secondary" size="lg"> Call (214) 682-6371 </Button>
    </div>
    <p class="mt-6 text-sm text-warm-gray">
      Mon-Fri 9am-5pm, Sat 9am-3:30pm &bull; Free pickup and delivery in DFW
    </p>
  </div>
</section>
