---
import { Image } from 'astro:assets';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';

import restoration from '../../assets/images/services/what-we-do-1.png';
import upholstery from '../../assets/images/services/what-we-do-2.png';
import refinishing from '../../assets/images/services/what-we-do-3.png';

const services = [
  {
    title: 'Antique Restoration',
    description:
      'We carefully restore antique furniture to its original beauty while preserving the character and patina that make each piece unique. From structural repairs to finish matching, every detail matters.',
    image: restoration,
    imageAlt: 'Craftsman inspecting an ornately carved antique cabinet during restoration',
    link: '/services/#restoration',
  },
  {
    title: 'Custom Upholstery',
    description:
      'Transform your furniture with premium fabrics and expert craftsmanship. We handle everything from simple cushion replacements to full reupholstery of complex pieces with tufting and trim.',
    image: upholstery,
    imageAlt: 'Restored antique Victorian sofa with floral upholstery fabric',
    link: '/services/#upholstery',
  },
  {
    title: 'Refinishing',
    description:
      'Bring out the natural beauty of the wood with our refinishing services. We strip, sand, stain, and seal using techniques matched to your piece, whether it needs a modern update or a period-correct restoration.',
    image: refinishing,
    imageAlt: 'Hands applying wood stain to a round table surface during refinishing',
    link: '/services/#refinishing',
  },
];
---

<section class="py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading tagline="What We Do"> Expert Furniture Care </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4">
      {
        services.map((service, index) => (
          <a
            href={service.link}
            class="group bg-cream-dark/50 rounded-sm overflow-hidden hover:shadow-xl transition-all duration-300 border border-gold/10 hover:border-gold/30 reveal"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={service.image}
                alt={service.imageAlt}
                width={400}
                height={300}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-8">
              <h3 class="font-serif text-xl text-wood group-hover:text-gold transition-colors">
                {service.title}
              </h3>
              <p class="text-charcoal-light text-sm leading-relaxed mt-3">{service.description}</p>
              <span class="inline-flex items-center gap-1 mt-4 text-gold text-sm font-semibold group-hover:gap-2 transition-all">
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <div class="text-center mt-12">
      <Button href="/services/" variant="outline" size="md"> View All Services </Button>
    </div>
  </div>
</section>
