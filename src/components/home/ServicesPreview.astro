---
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';

const services = [
  {
    title: 'Antique Restoration',
    description:
      'We carefully restore antique furniture to its original beauty while preserving the character and patina that make each piece unique. From structural repairs to finish matching, every detail matters.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    link: '/services/#restoration',
  },
  {
    title: 'Custom Upholstery',
    description:
      'Transform your furniture with premium fabrics and expert craftsmanship. We handle everything from simple cushion replacements to full reupholstery of complex pieces with tufting and trim.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" /></svg>`,
    link: '/services/#upholstery',
  },
  {
    title: 'Refinishing',
    description:
      'Bring out the natural beauty of the wood with our refinishing services. We strip, sand, stain, and seal using techniques matched to your piece, whether it needs a modern update or a period-correct restoration.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
    link: '/services/#refinishing',
  },
];
---

<section class="py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading tagline="What We Do"> Expert Furniture Care </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4">
      {
        services.map((service, index) => (
          <a
            href={service.link}
            class="group bg-cream-dark/50 rounded-sm p-8 hover:shadow-xl transition-all duration-300 border border-gold/10 hover:border-gold/30 reveal"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="w-14 h-14 bg-wood/5 rounded-sm flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-cream transition-all duration-300">
              <Fragment set:html={service.icon} />
            </div>
            <h3 class="font-serif text-xl text-wood mt-6 mb-3 group-hover:text-gold transition-colors">
              {service.title}
            </h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{service.description}</p>
            <span class="inline-flex items-center gap-1 mt-4 text-gold text-sm font-semibold group-hover:gap-2 transition-all">
              Learn more
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </span>
          </a>
        ))
      }
    </div>

    <div class="text-center mt-12 reveal">
      <Button href="/services/" variant="outline" size="md"> View All Services </Button>
    </div>
  </div>
</section>
