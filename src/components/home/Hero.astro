---
import Button from '../ui/Button.astro';
---

<section class="relative bg-wood overflow-hidden texture-wood">
  <div class="relative z-10">
    <!-- Subtle decorative gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-wood-dark/40 via-transparent to-gold/10">
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 lg:py-40">
      <div class="max-w-3xl">
        <!-- Tagline -->
        <p class="text-gold font-semibold tracking-wider uppercase text-sm mb-4 reveal">
          Dallas-Fort Worth's Trusted Craftsmen
        </p>

        <!-- Main Heading -->
        <h1
          class="font-serif text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-cream font-bold leading-tight reveal"
        >
          Restoring Craftsmanship
          <span class="block mt-2">
            <span class="text-gold">Since 1980</span>
          </span>
        </h1>

        <!-- Subheading -->
        <p class="mt-6 text-lg md:text-xl text-cream/80 max-w-2xl leading-relaxed reveal">
          Expert furniture repair, antique restoration, and custom upholstery. We bring your
          treasured pieces back to life with the care they deserve.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4 reveal">
          <Button href="/contact/" variant="primary" size="lg"> Get a Free Estimate </Button>
          <Button
            href="/portfolio/"
            variant="outline"
            size="lg"
            class="border-cream/40 text-cream hover:bg-cream/10 hover:text-cream"
          >
            View Our Work
          </Button>
        </div>

        <!-- Trust Signals -->
        <div class="mt-12 flex flex-wrap gap-x-8 gap-y-3 text-cream/60 text-sm reveal">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <span>35+ Years Experience</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span>Free Pickup & Delivery</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
            >
            <span>Family Owned & Operated</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
