---
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';
import heroBanner from '../../assets/images/hero/home-banner.png';
---

<section class="relative bg-wood overflow-hidden">
  <!-- Hero Background Image -->
  <div class="absolute inset-0">
    <Image
      src={heroBanner}
      alt=""
      class="w-full h-full object-cover"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-wood-dark/70"></div>
  </div>

  <div class="relative z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 lg:py-40">
      <div class="max-w-3xl">
        <!-- Tagline -->
        <p class="text-gold font-semibold tracking-wider uppercase text-sm mb-4">
          Dallas-Fort Worth's Trusted Craftsmen
        </p>

        <!-- Main Heading -->
        <h1
          class="font-serif text-4xl md:text-5xl lg:text-6xl xl:text-7xl text-cream font-bold leading-tight"
        >
          Restoring Craftsmanship
          <span class="block mt-2">
            <span class="text-gold">Since 1980</span>
          </span>
        </h1>

        <!-- Subheading -->
        <p class="mt-6 text-lg md:text-xl text-cream/80 max-w-2xl leading-relaxed">
          Expert furniture repair, antique restoration, and custom upholstery from our workshop
          in Wylie, TX. We bring your treasured pieces back to life with the care they deserve.
        </p>

        <!-- CTA Buttons -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <Button href="/contact/" variant="primary" size="lg"> Get a Free Estimate </Button>
          <a
            href="/portfolio/"
            class="inline-flex items-center justify-center font-semibold rounded-sm transition-all duration-300 cursor-pointer px-8 py-4 text-lg border-2 border-cream text-cream hover:bg-cream hover:text-wood"
          >
            View Our Work
          </a>
        </div>

        <!-- Trust Signals -->
        <div class="mt-12 flex flex-wrap gap-x-8 gap-y-3 text-cream/60 text-sm">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20"
              ><path
                d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
              ></path></svg
            >
            <span>35+ Years Experience</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span>Free Pickup & Delivery</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
            >
            <span>Family Owned & Operated</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
