---
import SectionHeading from '../ui/SectionHeading.astro';
import testimonials from '../../content/testimonials.json';
---

<section class="py-20 md:py-28 bg-wood-dark texture-wood">
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading tagline="Customer Reviews" class="[&_h2]:text-cream [&_p]:text-gold-light">
      <span class="text-cream">What Our Customers Say</span>
    </SectionHeading>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-4">
      {
        testimonials.map((testimonial, index) => (
          <div
            class="bg-cream/5 backdrop-blur-sm border border-cream/10 rounded-sm p-8"
          >
            <div class="flex gap-1 mb-4">
              {Array.from({ length: testimonial.rating }).map(() => (
                <svg class="w-5 h-5 text-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-cream/90 text-lg leading-relaxed font-serif italic">
              "{testimonial.quote}"
            </blockquote>

            <div class="mt-6 flex items-center gap-3">
              <div class="w-10 h-10 bg-gold/20 rounded-full flex items-center justify-center">
                <span class="text-gold font-semibold text-sm">{testimonial.author.charAt(0)}</span>
              </div>
              <span class="text-cream/70 text-sm font-medium">{testimonial.author}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
