---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: string;
  ogImage?: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  additionalSchema?: string | string[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalPath = '',
  ogType = 'website',
  ogImage = '/og-default.png',
  breadcrumbs = [],
  additionalSchema = [],
  noindex = false,
} = Astro.props;

const siteUrl = 'https://aredrepair.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// LocalBusiness schema - consistent on every page
const localBusinessSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${siteUrl}/#business`,
  'name': 'ARED Furniture Repair & Antique Restoration',
  'image': `${siteUrl}/og-default.png`,
  'url': siteUrl,
  'telephone': '+12146826371',
  'priceRange': '$$',
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': '10 Regency Dr Bldg B',
    'addressLocality': 'Wylie',
    'addressRegion': 'TX',
    'postalCode': '75098',
    'addressCountry': 'US',
  },
  'geo': {
    '@type': 'GeoCoordinates',
    'latitude': 33.0151,
    'longitude': -96.5389,
  },
  'openingHoursSpecification': [
    {
      '@type': 'OpeningHoursSpecification',
      'dayOfWeek': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      'opens': '09:00',
      'closes': '17:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      'dayOfWeek': 'Saturday',
      'opens': '09:00',
      'closes': '15:30',
    },
  ],
  'areaServed': {
    '@type': 'GeoCircle',
    'geoMidpoint': {
      '@type': 'GeoCoordinates',
      'latitude': 32.7767,
      'longitude': -96.797,
    },
    'geoRadius': '80000',
  },
  'sameAs': [
    'https://www.facebook.com/FurnitureRepairing/',
    'https://www.instagram.com/aredfurnituretx/',
    'https://x.com/aredfurnituretx',
    'https://www.pinterest.com/aredfurnituretx/',
    'https://www.yelp.com/biz/ared-furniture-repair-and-antique-restoration-wylie',
  ],
  'description':
    'Family-owned furniture repair and antique restoration serving the Dallas-Fort Worth metroplex since 1980. Expert restoration, upholstery, refinishing, and specialty work.',
  'aggregateRating': {
    '@type': 'AggregateRating',
    'ratingValue': '5',
    'bestRating': '5',
    'ratingCount': '6',
    'reviewCount': '6',
  },
  'review': [
    {
      '@type': 'Review',
      'author': { '@type': 'Person', 'name': 'Chris S' },
      'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
      'reviewBody': 'I had an old dining table from my grandma restored by Arnold and his team. Wow I can\'t believe the craftsmanship of these guys. I will be back for sure.',
    },
    {
      '@type': 'Review',
      'author': { '@type': 'Person', 'name': 'John Murray' },
      'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
      'reviewBody': 'They did a fantastic job remodeling an antique chair. The chair was over 150 years old, in my wife\'s family for generations, and in bad shape from years of neglect. They worked with me to get it just the way I wanted it using fabric I provided. I could not be happier. It was not cheap ($1200.00), but this was not something I could have done myself.',
    },
    {
      '@type': 'Review',
      'author': { '@type': 'Person', 'name': 'Marc Entsminger' },
      'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
      'reviewBody': 'I took in an old radio that had been sitting in a corner of my garage since the 1980\'s. This radio was originally built in the 1930\'s and was damaged. They took the radio and made it like new! It now looks like something out of a Hollywood movie. I am so impressed with the detail of their work and you cannot see where any of the damage was and the finish and color are extraordinary.',
    },
    {
      '@type': 'Review',
      'author': { '@type': 'Person', 'name': 'Nancy Volkert' },
      'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
      'reviewBody': 'ARED restored my long awaited settee given to me from my Grandfather so long ago and over the years had gotten into quite a disarray! The craftsmanship was impeccable, I was so excited to see the settee restored to its former glory, it\'s quite the masterpiece. This piece of furniture had so many memories and now I can hand it down to my children to create more.',
    },
    {
      '@type': 'Review',
      'author': { '@type': 'Person', 'name': 'Chase Green' },
      'reviewRating': { '@type': 'Rating', 'ratingValue': '5', 'bestRating': '5' },
      'reviewBody': 'Their work is so amazing. By far the best antique restorations in DFW.',
    },
  ],
});

// Breadcrumb schema
const breadcrumbSchema =
  breadcrumbs.length > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        'itemListElement': [
          { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': siteUrl },
          ...breadcrumbs.map((crumb, index) => ({
            '@type': 'ListItem',
            'position': index + 2,
            'name': crumb.name,
            'item': `${siteUrl}${crumb.url}`,
          })),
        ],
      })
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/favicon-192.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ARED Furniture Repair & Antique Restoration - Expert craftsmen serving DFW since 1980" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="ARED Furniture Repair & Antique Restoration" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="ARED Furniture Repair & Antique Restoration - Expert craftsmen serving DFW since 1980" />

    <!-- Fonts are self-hosted via @fontsource (imported in global.css) -->

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={localBusinessSchema} />
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
    {Array.isArray(additionalSchema)
      ? additionalSchema.map((schema) => <script type="application/ld+json" set:html={schema} />)
      : additionalSchema && <script type="application/ld+json" set:html={additionalSchema} />
    }
    <!-- Cloudflare Web Analytics (production only) -->
    {import.meta.env.PROD && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "26b1683fc39741fe9a390e5ad13d37ff"}'></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col texture-parchment">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <Header />

    <main id="main-content" class="flex-1 pt-16 md:pt-20">
      <slot />
    </main>

    <Footer />

    <!-- Sticky Mobile CTA Bar -->
    <div
      id="mobile-cta"
      class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-wood/95 backdrop-blur-sm border-t border-gold/20 translate-y-full transition-transform duration-300"
    >
      <div class="flex">
        <a
          href="tel:+12146826371"
          class="flex-1 flex items-center justify-center gap-2 py-3 text-cream text-sm font-semibold hover:bg-wood-light transition-colors"
        >
          <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
          </svg>
          Call Now
        </a>
        <div class="w-px bg-gold/20"></div>
        <a
          href="/contact/"
          class="flex-1 flex items-center justify-center gap-2 py-3 bg-burgundy text-cream text-sm font-semibold hover:bg-burgundy-dark transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          Free Estimate
        </a>
      </div>
    </div>

    <!-- Scroll to Top Button -->
    <button
      id="scroll-top"
      class="fixed bottom-20 lg:bottom-8 right-6 z-30 w-11 h-11 bg-wood/90 text-cream rounded-full shadow-lg flex items-center justify-center opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:bg-gold cursor-pointer"
      aria-label="Scroll to top"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
      </svg>
    </button>

    <!-- Scroll reveal observer + scroll-to-top + mobile CTA -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
      );

      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      // Scroll-to-top button + mobile CTA bar
      const scrollBtn = document.getElementById('scroll-top');
      const mobileCta = document.getElementById('mobile-cta');

      if (scrollBtn) {
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      let lastScrollY = 0;
      window.addEventListener('scroll', () => {
        const y = window.scrollY;

        // Show/hide scroll-to-top
        if (scrollBtn) {
          if (y > 500) {
            scrollBtn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
            scrollBtn.classList.add('opacity-100', 'translate-y-0');
          } else {
            scrollBtn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
            scrollBtn.classList.remove('opacity-100', 'translate-y-0');
          }
        }

        // Show/hide mobile CTA bar (show after scrolling past hero, hide when scrolling up near top)
        if (mobileCta) {
          if (y > 300) {
            mobileCta.classList.remove('translate-y-full');
          } else {
            mobileCta.classList.add('translate-y-full');
          }
        }

        lastScrollY = y;
      });
    </script>
  </body>
</html>
