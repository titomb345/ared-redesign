---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import ServicesPreview from '../components/home/ServicesPreview.astro';
import Testimonials from '../components/home/Testimonials.astro';
import CTASection from '../components/home/CTASection.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';

import singerTable from '../assets/images/portfolio/refurbishing-furniture.jpg';
import cabinetRestore from '../assets/images/portfolio/furniture-upholstery.jpg';
import vintageMantel from '../assets/images/portfolio/vintage-furniture.jpg';

const websiteSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'ARED Furniture Repair & Antique Restoration',
  'url': 'https://aredrepair.com',
});

const featuredProjects = [
  {
    title: 'Singer Sewing Table Restoration',
    image: singerTable,
    imageAlt: 'Before and after restoration of an antique Singer sewing machine table',
    description:
      'Complete top replacement and finish restoration on a vintage Singer sewing table.',
  },
  {
    title: 'Antique Cabinet Revival',
    image: cabinetRestore,
    imageAlt: 'Before and after restoration of a glass-front antique display cabinet',
    description:
      'Glass door repair, structural reinforcement, and full finish renewal.',
  },
  {
    title: 'Vintage Mantel Clock',
    image: vintageMantel,
    imageAlt: 'Restored antique mantel clock with gold decorative feet',
    description:
      'Clock case refinished, mechanics cleaned and oiled, brass hardware restored.',
  },
];
---

<Layout
  title="ARED Furniture Repair | Antique Restoration Wylie TX"
  description="Expert furniture repair and antique restoration in Wylie, TX. Family-owned since 1980, serving DFW with free pickup and delivery. Call (214) 682-6371."
  canonicalPath="/"
  additionalSchema={websiteSchema}
>
  <!-- Hero Section -->
  <Hero />

  <!-- Services Preview -->
  <ServicesPreview />

  <!-- Before/After Showcase -->
  <section class="py-20 md:py-28 bg-cream-dark/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading tagline="Featured Work"> Before & After Transformations </SectionHeading>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4">
        {
          featuredProjects.map((project, index) => (
            <div
              class="rounded-sm overflow-hidden border border-gold/10 bg-cream shadow-sm hover:shadow-xl transition-all group"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <Image
                  src={project.image}
                  alt={project.imageAlt}
                  width={480}
                  height={360}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-5">
                <h3 class="font-serif text-lg text-wood">{project.title}</h3>
                <p class="text-sm text-charcoal-light mt-1">{project.description}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-12">
        <a
          href="/portfolio/"
          class="inline-flex items-center gap-2 text-gold font-semibold hover:text-gold-dark transition-colors"
        >
          View Full Portfolio
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
          >
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <Testimonials />

  <!-- Final CTA -->
  <CTASection />
</Layout>
