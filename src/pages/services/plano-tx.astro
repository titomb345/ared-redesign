---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';
import SectionHeading from '../../components/ui/SectionHeading.astro';
import { services } from '../../data/services';

const city = 'Plano';
const state = 'TX';
const driveTime = '15-20 minutes';
const neighborhoods = [
  'West Plano',
  'East Plano',
  'Legacy West',
  'Willow Bend',
  'Preston Hollow',
  'Kings Ridge',
  'Deerfield',
  'Hunters Glen',
  'Shepards Glen',
  'Old Town Plano',
];

const areaSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  'serviceType': 'Furniture Repair and Antique Restoration',
  'provider': {
    '@type': 'LocalBusiness',
    '@id': 'https://aredrepair.com/#business',
    'name': 'ARED Furniture Repair & Antique Restoration',
    'telephone': '+12146826371',
  },
  'areaServed': {
    '@type': 'City',
    'name': `${city}, ${state}`,
  },
  'description': `Expert furniture repair, antique restoration, and custom upholstery serving ${city}, ${state}. Free pickup and delivery.`,
});
---

<Layout
  title={`Furniture Repair & Antique Restoration in ${city}, TX | ARED`}
  description={`Expert furniture repair and antique restoration serving ${city}, TX. Free pickup and delivery from our Wylie workshop, just ${driveTime} away. Call (214) 682-6371.`}
  canonicalPath={`/services/plano-tx/`}
  breadcrumbs={[
    { name: 'Services', url: '/services/' },
    { name: `${city}, TX`, url: `/services/plano-tx/` },
  ]}
  additionalSchema={areaSchema}
>
  <!-- Page Header -->
  <section class="bg-wood texture-wood py-16 md:py-24">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold font-semibold tracking-wider uppercase text-sm mb-3">Serving {city}, TX</p>
      <h1 class="font-serif text-4xl md:text-5xl text-cream font-bold leading-tight">
        Furniture Repair & Antique Restoration in {city}
      </h1>
      <p class="mt-4 text-cream/70 text-lg max-w-2xl">
        Our Wylie workshop is just {driveTime} from {city}. We pick up your furniture, restore
        it with care, and deliver it back to your door. No charge for pickup or delivery, ever.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4">
        <Button href="/contact/" variant="primary" size="lg">Get a Free Estimate</Button>
        <a
          href="tel:+12146826371"
          class="inline-flex items-center justify-center font-semibold rounded-sm transition-all duration-300 cursor-pointer px-8 py-4 text-lg border-2 border-cream text-cream hover:bg-cream hover:text-wood"
        >
          Call (214) 682-6371
        </a>
      </div>
    </div>
  </section>

  <!-- Why Plano residents trust ARED -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl md:text-4xl text-wood font-bold mb-4">
        Why {city} Homeowners Choose ARED
      </h2>
      <div class="ornament">
        <div class="ornament-diamond"></div>
      </div>

      <div class="space-y-5 text-charcoal-light leading-relaxed mt-4">
        <p>
          Plano is home to some of the most beautiful furniture in the DFW metroplex. Many
          neighborhoods here were built during the 1980s and 1990s housing boom, and the families
          who moved in furnished their homes with quality pieces - formal dining sets, china cabinets,
          upholstered armchairs, and solid wood bedroom suites. Thirty or forty years later, those
          pieces are still structurally sound but showing their age. Finishes are worn, upholstery
          is faded, and joints have loosened from decades of use.
        </p>
        <p>
          That is exactly where we come in. Rather than replacing a solid oak dining table with
          something from a chain store, why not have it refinished? The wood underneath is better
          than anything you will find new. We see this all the time with Plano customers - they
          come to us expecting to hear "just buy a new one," and instead we show them what their
          existing furniture can look like with proper restoration.
        </p>
        <p>
          We also work with a lot of Plano residents who have inherited furniture from parents and
          grandparents. A settee from the old country, a rocking chair that has been in the family
          for generations, a dresser that traveled across the state in the back of a truck and
          arrived with a cracked leg and chipped veneer. These are the projects we love. We
          understand that the value of these pieces goes far beyond what any price tag can capture.
        </p>
      </div>
    </div>
  </section>

  <!-- Services we provide -->
  <section class="py-16 md:py-24 bg-cream-dark/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading tagline="What We Do">
        Our Services for {city} Residents
      </SectionHeading>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-4">
        {services.map((service, index) => (
          <div
            class="bg-cream border border-gold/10 rounded-sm p-6 reveal"
            style={`transition-delay: ${index * 100}ms`}
          >
            <h3 class="font-serif text-xl text-wood mb-2">{service.name}</h3>
            <p class="text-charcoal-light text-sm leading-relaxed">{service.shortDescription}</p>
            <ul class="mt-3 space-y-1">
              {service.features.slice(0, 3).map((feature) => (
                <li class="flex items-start gap-2 text-sm text-charcoal-light">
                  <svg class="w-4 h-4 text-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/services/" class="text-gold font-semibold hover:text-gold-dark transition-colors inline-flex items-center gap-1">
          View full service details
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How it works for Plano -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl md:text-4xl text-wood font-bold text-center mb-4">
        How It Works from {city}
      </h2>
      <div class="ornament">
        <div class="ornament-diamond"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
        <div class="text-center reveal">
          <div class="w-14 h-14 mx-auto bg-gold/10 border border-gold/20 rounded-full flex items-center justify-center mb-4">
            <span class="font-serif text-xl text-gold font-bold">1</span>
          </div>
          <h3 class="font-serif text-lg text-wood mb-2">Call or Message Us</h3>
          <p class="text-sm text-charcoal-light leading-relaxed">
            Tell us about your piece and what it needs. We will give you an honest estimate over the
            phone or ask you to send a few photos for a closer look.
          </p>
        </div>

        <div class="text-center reveal" style="transition-delay: 100ms">
          <div class="w-14 h-14 mx-auto bg-gold/10 border border-gold/20 rounded-full flex items-center justify-center mb-4">
            <span class="font-serif text-xl text-gold font-bold">2</span>
          </div>
          <h3 class="font-serif text-lg text-wood mb-2">We Pick It Up</h3>
          <p class="text-sm text-charcoal-light leading-relaxed">
            We drive to your {city} home, carefully load your furniture, and bring it to our
            workshop in Wylie - about {driveTime} east on the George Bush Turnpike. No charge.
          </p>
        </div>

        <div class="text-center reveal" style="transition-delay: 200ms">
          <div class="w-14 h-14 mx-auto bg-gold/10 border border-gold/20 rounded-full flex items-center justify-center mb-4">
            <span class="font-serif text-xl text-gold font-bold">3</span>
          </div>
          <h3 class="font-serif text-lg text-wood mb-2">Restore & Deliver</h3>
          <p class="text-sm text-charcoal-light leading-relaxed">
            We do the work, keep you updated, and deliver your restored piece right back to your
            door when it is ready. Most projects take 2 to 6 weeks.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Plano neighborhoods we serve -->
  <section class="py-16 md:py-24 bg-cream-dark/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl text-wood font-bold mb-4">
        {city} Neighborhoods We Serve
      </h2>
      <div class="ornament">
        <div class="ornament-diamond"></div>
      </div>
      <p class="text-charcoal-light mt-4 mb-8">
        We pick up and deliver throughout {city} and the surrounding area. Here are some of the
        neighborhoods we regularly visit:
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        {neighborhoods.map((area) => (
          <span class="bg-cream border border-gold/10 px-4 py-2 rounded-sm text-sm text-charcoal">
            {area}
          </span>
        ))}
      </div>
      <p class="text-sm text-warm-gray mt-6">
        Don't see your neighborhood? We serve all of {city} and the surrounding communities.
      </p>
    </div>
  </section>

  <!-- What Plano customers commonly bring us -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl text-wood font-bold mb-4">
        Common Projects from {city} Homes
      </h2>
      <div class="ornament">
        <div class="ornament-diamond"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-6 mt-6">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Formal dining sets</p>
            <p class="text-sm text-charcoal-light">Refinishing worn tabletops, regluing loose chair joints, and reupholstering seat cushions on sets that have hosted decades of family dinners.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Inherited antiques</p>
            <p class="text-sm text-charcoal-light">Restoring pieces passed down from parents and grandparents - dressers, china cabinets, rocking chairs, and trunks with sentimental value that no store can replace.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Upholstered sofas and armchairs</p>
            <p class="text-sm text-charcoal-light">Full reupholstery on living room furniture - new fabric, springs, padding, and frame repair so your favorite seat feels brand new again.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Estate sale and auction finds</p>
            <p class="text-sm text-charcoal-light">Plano and the surrounding area have an active estate sale scene. We regularly restore pieces customers pick up at sales in {city}, Allen, and McKinney.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Moving and water damage repair</p>
            <p class="text-sm text-charcoal-light">Scratches, dents, and water rings from moves or accidents. We also help with insurance documentation if your piece was damaged in a covered event.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-medium text-charcoal">Style updates on quality furniture</p>
            <p class="text-sm text-charcoal-light">Love the bones of a piece but not the finish? We can give solid furniture a completely new look - darker stain, lighter wash, or even an antique patina on a newer piece.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-wood texture-wood">
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-cream font-bold">
        {city} Furniture Repair Starts with a Phone Call
      </h2>
      <p class="mt-4 text-cream/70 text-lg">
        Tell us about your piece. We will give you an honest assessment, a fair estimate, and
        pick it up from your {city} home at no charge.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact/" variant="primary" size="lg">Get a Free Estimate</Button>
        <a
          href="tel:+12146826371"
          class="inline-flex items-center justify-center font-semibold rounded-sm transition-all duration-300 cursor-pointer px-8 py-4 text-lg border-2 border-cream text-cream hover:bg-cream hover:text-wood"
        >
          Call (214) 682-6371
        </a>
      </div>
      <p class="mt-6 text-cream/50 text-sm">
        Mon-Fri 9am-5pm, Sat 9am-3:30pm &bull; Free pickup and delivery in {city} and all of DFW
      </p>
    </div>
  </section>
</Layout>
