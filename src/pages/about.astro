---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import testimonials from '../content/testimonials.json';
---

<Layout
  title="About ARED | Family-Owned Restoration Since 1980"
  description="Learn about ARED Furniture Repair, a family-owned business in Wylie, TX. 35+ years of expert furniture restoration, upholstery, and refinishing."
  canonicalPath="/about/"
  breadcrumbs={[{ name: 'About', url: '/about/' }]}
>
  <!-- Page Header -->
  <section class="bg-wood texture-wood py-16 md:py-24">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold font-semibold tracking-wider uppercase text-sm mb-3">Our Story</p>
      <h1 class="font-serif text-4xl md:text-5xl text-cream font-bold">About ARED</h1>
      <p class="mt-4 text-cream/70 text-lg max-w-2xl">
        More than four decades of bringing furniture back to life, one piece at a time.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        <!-- Image Placeholder -->
        <div class="lg:col-span-2 reveal">
          <div
            class="aspect-[3/4] bg-wood-light/20 border border-gold/10 rounded-sm flex items-center justify-center"
          >
            <div class="text-center text-warm-gray">
              <svg
                class="w-16 h-16 mx-auto mb-3 opacity-40"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
              <p class="text-sm">Photo of Arnold<br />in the Workshop</p>
            </div>
          </div>
        </div>

        <!-- Story Content -->
        <div class="lg:col-span-3 reveal">
          <h2 class="font-serif text-3xl text-wood mb-6">A Family Tradition of Craftsmanship</h2>

          <div class="space-y-5 text-charcoal-light leading-relaxed">
            <p>
              ARED Furniture Repair & Antique Restoration began in 1980 with a simple idea: that
              well-made furniture deserves a second life. What started as a one-person operation has
              grown into a trusted name across the Dallas-Fort Worth metroplex, but the philosophy
              has never changed.
            </p>
            <p>
              Arnold, our founder and lead craftsman, learned the art of furniture restoration the
              old-fashioned way. Years of working alongside experienced woodworkers taught him that
              there are no shortcuts worth taking when it comes to quality work. That hands-on
              training shows in every joint he tightens, every finish he applies, and every piece he
              sends home looking better than it has in decades.
            </p>
            <p>
              Over 35 years later, we still operate from our workshop in Wylie, Texas. We have never
              been interested in cutting corners or rushing through projects. Each piece of
              furniture that comes through our doors gets the same careful attention, whether it is
              a museum-quality antique or a well-loved family rocking chair.
            </p>
            <p>
              Our customers often tell us that what sets us apart is the personal touch. When you
              call ARED, you talk to the people who will actually be working on your furniture. We
              listen to your goals for the piece, discuss the best approach, and keep you informed
              throughout the process. That kind of direct relationship with the craftsman is rare
              these days, and we intend to keep it that way.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 md:py-24 bg-cream-dark/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading tagline="What We Stand For"> Our Values </SectionHeading>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-4">
        <div class="text-center p-8 reveal">
          <div
            class="w-16 h-16 mx-auto bg-wood/5 rounded-full flex items-center justify-center mb-6"
          >
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-wood mb-3">Authenticity</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            We believe in preserving the original character of every piece. Restoration is not about
            making something look brand new. It is about honoring the craftsmanship that came before
            us while ensuring the piece will endure for generations to come.
          </p>
        </div>

        <div class="text-center p-8 reveal" style="transition-delay: 100ms">
          <div
            class="w-16 h-16 mx-auto bg-wood/5 rounded-full flex items-center justify-center mb-6"
          >
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
              ></path>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-wood mb-3">Craftsmanship</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Quality work takes time, and we never rush. We use traditional joinery techniques,
            hand-selected materials, and finishing methods proven over centuries. Every repair is
            made to last, not just to look good for a few months.
          </p>
        </div>

        <div class="text-center p-8 reveal" style="transition-delay: 200ms">
          <div
            class="w-16 h-16 mx-auto bg-wood/5 rounded-full flex items-center justify-center mb-6"
          >
            <svg class="w-8 h-8 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h3 class="font-serif text-xl text-wood mb-3">Customer Care</h3>
          <p class="text-charcoal-light text-sm leading-relaxed">
            Your furniture matters to you, and that makes it matter to us. We communicate openly
            about timelines, costs, and expectations. Free pickup and delivery is just one way we
            make the process easier for our customers across DFW.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading tagline="Customer Reviews"> Words From Our Customers </SectionHeading>

      <div class="space-y-8 mt-4">
        {
          testimonials.map((testimonial, index) => (
            <div
              class="bg-cream-dark/50 border border-gold/10 rounded-sm p-8 reveal"
              style={`transition-delay: ${index * 100}ms`}
            >
              <div class="flex gap-1 mb-3">
                {Array.from({ length: testimonial.rating }).map(() => (
                  <svg class="w-4 h-4 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <blockquote class="text-charcoal text-lg leading-relaxed font-serif italic">
                "{testimonial.quote}"
              </blockquote>
              <p class="mt-4 text-warm-gray font-medium text-sm">- {testimonial.author}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-wood texture-wood">
    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl md:text-4xl text-cream font-bold">
        Let's Talk About Your Furniture
      </h2>
      <p class="mt-4 text-cream/70 text-lg">
        We would love to hear about your project. Reach out for a free estimate and let us show you
        what 35+ years of experience looks like.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/contact/" variant="primary" size="lg">Contact Us Today</Button>
        <Button
          href="tel:+12146826371"
          variant="outline"
          size="lg"
          class="border-cream/40 text-cream hover:bg-cream/10 hover:text-cream"
        >
          Call (214) 682-6371
        </Button>
      </div>
    </div>
  </section>
</Layout>
