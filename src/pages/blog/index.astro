---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Restoration Blog | ARED Furniture Repair"
  description="Tips, stories, and insights about furniture restoration, antique care, and wood finishing from the craftsmen at ARED in Wylie, TX."
  canonicalPath="/blog/"
  breadcrumbs={[{ name: 'Blog', url: '/blog/' }]}
>
  <!-- Page Header -->
  <section class="bg-wood texture-wood py-16 md:py-24">
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-gold font-semibold tracking-wider uppercase text-sm mb-3">From the Workshop</p>
      <h1 class="font-serif text-4xl md:text-5xl text-cream font-bold">Restoration Blog</h1>
      <p class="mt-4 text-cream/70 text-lg max-w-2xl">
        Stories and insights from decades of working with wood, fabric, and finish.
      </p>
    </div>
  </section>

  <!-- Coming Soon Content -->
  <section class="py-24 md:py-36">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 mx-auto bg-wood/5 rounded-full flex items-center justify-center mb-8">
        <svg class="w-10 h-10 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
          ></path>
        </svg>
      </div>
      <h2 class="font-serif text-3xl text-wood mb-4">Coming Soon</h2>
      <div class="ornament">
        <div class="ornament-diamond"></div>
      </div>
      <p class="mt-6 text-lg text-charcoal-light leading-relaxed">
        We are working on sharing our restoration knowledge, project stories, and furniture care
        tips. Check back soon for articles on topics like caring for antique wood finishes, choosing
        the right upholstery fabric, and recognizing quality craftsmanship.
      </p>
      <p class="mt-4 text-charcoal-light">
        In the meantime, feel free to <a
          href="/contact/"
          class="text-gold font-semibold hover:text-gold-dark transition-colors underline underline-offset-4"
          >reach out</a
        > with any furniture questions. We are always happy to help.
      </p>

      <div class="mt-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-gold font-semibold hover:text-gold-dark transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M7 16l-4-4m0 0l4-4m-4 4h18"></path></svg
          >
          Back to Home
        </a>
      </div>
    </div>
  </section>
</Layout>
